<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
    </style>

    <!-- Player theme -->
    <style name="PlayerTheme" parent="AppTheme">
        <item name="android:windowBackground">@color/player_background</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Lyrics theme -->
    <style name="LyricsTheme" parent="AppTheme">
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Leanback theme for TV -->
    <style name="LeanbackTheme" parent="Theme.Leanback">
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="browseTitleStyle">@style/BrowseTitleStyle</item>
    </style>

    <!-- Browse title style -->
    <style name="BrowseTitleStyle" parent="Widget.Leanback.BrowseTitle">
        <item name="android:textColor">@color/leanback_browse_title_color</item>
        <item name="android:textSize">24sp</item>
    </style>

    <!-- Card style -->
    <style name="CardStyle" parent="Widget.Leanback.ImageCardView">
        <item name="cardBackgroundColor">@color/background_dark</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- Button style -->
    <style name="ButtonStyle" parent="Widget.AppCompat.Button.Colored">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:background">@color/colorPrimary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- Text style -->
    <style name="TextStyle" parent="TextAppearance.AppCompat">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Title text style -->
    <style name="TitleTextStyle" parent="TextAppearance.AppCompat.Title">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>