<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Cloud backup rules -->
    <cloud-backup>
        <!-- Include application data -->
        <include domain="sharedpref" path="." />
        <include domain="database" path="." />
        <include domain="file" path="." />
        <include domain="external" path="." />
        
        <!-- Exclude cache directories -->
        <exclude domain="cache" path="." />
        <exclude domain="no_backup" path="." />
        
        <!-- Include media files -->
        <include domain="external" path="media" />
        
        <!-- Exclude temporary files -->
        <exclude domain="external" path="temp" />
        <exclude domain="external" path="cache" />
    </cloud-backup>
    
    <!-- Device-to-device transfer rules -->
    <device-transfer>
        <!-- Include application data -->
        <include domain="sharedpref" path="." />
        <include domain="database" path="." />
        <include domain="file" path="." />
        <include domain="external" path="." />
        
        <!-- Exclude cache directories -->
        <exclude domain="cache" path="." />
        <exclude domain="no_backup" path="." />
        
        <!-- Include media files -->
        <include domain="external" path="media" />
    </device-transfer>
</data-extraction-rules>